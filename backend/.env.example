# Application environment
APP_ENV=development
LOG_LEVEL=INFO

# Database (PostgreSQL preferred for phase 2+)
DATABASE_URL=postgresql://market_user:RHUbWSqm2mbnJ7TUn16WFbLvaEqUGT48@dpg-d7561h7fte5s7387mkd0-a.singapore-postgres.render.com/market_trend
REDIS_URL=redis://default:jBnfSAiIIDRqh0pBVeMVqQ01wbCzDG7v@redis-15578.crce185.ap-seast-1-1.ec2.cloud.redislabs.com:15578
REDIS_JOB_QUEUE_NAME=market.jobs

# API behavior
CORS_ORIGINS=http://localhost:5173,https://trendanalyserai.vercel.app/
TOKEN_TTL_MINUTES=120

# Scheduler + ingestion
INGESTION_SCHEDULER_ENABLED=1
INGESTION_INTERVAL_SECONDS=900
INGESTION_BATCH_SIZE=4

# Request controls (phase 3)
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=180
MAX_REQUEST_BODY_BYTES=512000

# Stricter auth/session controls
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_SECONDS=600
AUTH_REQUIRE_PASSWORD_UPPER=1
AUTH_REQUIRE_PASSWORD_LOWER=1
AUTH_REQUIRE_PASSWORD_DIGIT=1

# OpenTelemetry (optional)
OTEL_ENABLED=0
OTEL_SERVICE_NAME=caresense-api
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_INSECURE=1

# RAG controls
RAG_MAX_CHUNKS=8
